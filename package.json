{
  "name": "vs-journal",
  "displayName": "VS Journal",
  "description": "%extension.description%",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "journal",
    "memo",
    "notes",
    "tagging",
    "howm-inspired"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "vs-journal.newEntry",
        "title": "%command.newEntry%",
        "icon": "$(add)"
      },
      {
        "command": "vs-journal.previewEntry",
        "title": "%command.previewEntry%"
      },
      {
        "command": "vs-journal.selectJournalDir",
        "title": "%command.selectJournalDir%",
        "icon": "$(gear)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "%config.title%",
      "properties": {
        "vsJournal.journalDir": {
          "type": "string",
          "markdownDescription": "%config.journalDir.markdownDescription%"
        },
        "vsJournal.autoSave": {
          "type": "number",
          "default": 800,
          "minimum": 0,
          "description": "%config.autoSave%",
          "markdownDescription": "%config.autoSaveMarkdown%"
        },
        "vsJournal.enableDateTime": {
          "type": "boolean",
          "default": true,
          "description": "%config.enableDateTime.description%",
          "markdownDescription": "%config.enableDateTime.markdownDescription%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vsJournal",
          "title": "vsJournal",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "vsJournal": [
        {
          "id": "vsJournalTags",
          "name": "%tagsViewName%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "vsJournalTags",
        "contents": "%view.vsJournal.tags.empty%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vs-journal.newEntry",
          "when": "view == vsJournalTags",
          "group": "navigation@1"
        },
        {
          "command": "vs-journal.selectJournalDir",
          "when": "view == vsJournalTags",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "vs-journal.newEntry"
        },
        {
          "command": "vs-journal.previewEntry",
          "when": "view.vsJournalTags.visible"
        },
        {
          "command": "vs-journal.selectJournalDir"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vs-journal.newEntry",
        "key": "ctrl+alt+n",
        "mac": "cmd+option+n"
      },
      {
        "command": "vsJournalTags.focus",
        "key": "ctrl+alt+j",
        "mac": "cmd+option+j"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/marked": "^4.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.3",
    "npm-run-all": "^1.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.36.0"
  },
  "dependencies": {
    "marked": "4.3.0"
  }
}
